Examples/**/*64.exe
Settings/Workspace.ini
# Live per-user settings: window geometry, MRU lists, and [PersonalInfo] (name,
# e-mail, Git login). Every run rewrites it, so tracking it churned unrelated
# session state into commits and would publish personal details once those
# fields are filled in. The *shipped defaults* live in Settings/astoria.default.ini,
# which is tracked; SettingsService.LoadSettingsIni copies it when this file is
# missing, so a fresh clone or a released build creates its own on first run.
Settings/astoria.ini
# Debugger Reliability trace instrumentation output (local-only, per-machine)
Settings/debug_trace.log
Settings/*.pass1.log
Settings/*.pass2.log

# Per-control test programs: keep the sources, not the built binaries
Examples/Controls/**/*.exe
Examples/Controls/**/*.dll

# Integration test projects: keep the sources and fixtures, not the built binaries
# or their run artifacts (see Documentation/TestPlan.md).
Examples/Integration/**/*.exe
Examples/Integration/**/*.dll
Examples/Integration/**/*.db
Examples/Integration/**/a4_ticks.txt
Examples/Integration/**/a4_result.txt
Examples/Integration/**/a4_button_trace.txt

# WebView2 creates a per-program user-data folder beside the exe at runtime
*.exe.WebView2/
Examples/Integration/**/b1_result.txt
Examples/Integration/**/b6_result.txt
Examples/Integration/**/b10_result.txt
Examples/Integration/**/b4_result.txt
Examples/Integration/**/b7_result.txt
Examples/Integration/**/b3_result.txt
Examples/Integration/**/b13_result.txt
Examples/Integration/**/b11_result.txt
Examples/Integration/**/b12_result.txt
Examples/Integration/**/b2_result.txt
Examples/Integration/**/b5_result.txt
Examples/Integration/**/b8_result.txt
Examples/Integration/**/b9_result.txt
Examples/Integration/**/a7_result.txt
Examples/Integration/**/a2_test.db

# A3: the local copy carries a real DB password and must never be committed.
Examples/Integration/**/*.local.sql

# Generated by TestHarness/D1_ConsoleLifecycle.ps1, which deletes and recreates it on every run.
# Committing it would add churn and it is reproducible from the harness in seconds.
Projects/D1_ConsoleLifecycle/

# IDE scratch: timestamped .bak copies and temporary forms written during editing.
# Regenerated as needed and never part of a build.
Temp/

# Test-harness output and generated test projects.
# All are recreated by their harness or fixture on the next run; committing them adds churn,
# and A8-results.txt in particular reads as failures out of context (the FAIL lines are the
# fixture comparing against a suggested filename the tester chose not to use -- see TestPlan A8).
Examples/Integration/**/A8-results.txt
Projects/D5_McpMultiFile_*/
Projects/E_ScaleFixtures/
Projects/TestD2/
