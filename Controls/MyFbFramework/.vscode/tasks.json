{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "FreeBASIC Build",
            "type": "shell",
            "windows": {
                "command": "D:/FreeBasic/FreeBASIC-1.07.1-win32/fbc.exe",
                "args": [
                    "-g",
                    "-b",
                    "mff.bi",
                    "mff.rc",
                    "-x",
                    "../mff64.dll",
                    "-dll"
                ],
            },
            "options": {
                "cwd": "${workspaceFolder}/mff"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}